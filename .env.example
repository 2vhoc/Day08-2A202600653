# OpenAI (Task 10 - Generation)
OPENAI_API_KEY=sk-xxx
OPENAI_USE_API=0

# Jina AI (Task 7 - Reranking, optional)
JINA_API_KEY=jina_xxx

# PageIndex (Task 8 - Vectorless RAG)
PAGEINDEX_API_KEY=pi_xxx
PAGEINDEX_USE_API=0

# Weaviate Cloud (Task 4, optional - can use local Docker instead)
WEAVIATE_URL=https://xxx.weaviate.network
WEAVIATE_API_KEY=xxx

# Embedding model (if using API-based)
# COHERE_API_KEY=xxx

# Local web app defaults.
# Railway injects PORT automatically, so do not set PORT manually on Railway.
HOST=127.0.0.1
PORT=8501
